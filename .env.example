# ============ better-auth ============
# 用于签名 session / token。生产环境必须设置,本地随便填一个非空字符串即可。
# 生成方式:openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-in-production-please

# 应用对外可访问的根 URL,用于 OAuth callback 和 CORS
BETTER_AUTH_URL=http://localhost:3000

# ============ Database ============
# SQLite 文件路径(相对工程根),默认 ./data/app.db
DB_PATH=./data/app.db

# ============ GitHub OAuth ============
# 在 https://github.com/settings/developers 创建 OAuth App:
#   Homepage URL:  http://localhost:3000
#   Callback URL:  http://localhost:3000/api/auth/callback/github
# 留空则不启用 GitHub 登录入口(只走邮箱密码)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
