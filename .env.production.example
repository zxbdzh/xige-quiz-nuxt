# 生产环境 .env 示例
# 复制为 .env 后填入实际值

# ============ 必须设置 ============
# better-auth 密钥：openssl rand -base64 32
BETTER_AUTH_SECRET=这里填入生成的密钥

# 应用对外可访问的根 URL（OAuth callback 用，纯 origin，不要带子路径）
BETTER_AUTH_URL=https://你的域名.com

# ============ 子路径部署（可选）============
# 应用部署在子路径下时设置，如 /quiz/（首尾都要带斜杠）；根路径部署留空或填 /
# 注意:Docker 部署时该值由 Dockerfile / docker-compose 注入,此处仅作记录
# NUXT_APP_BASE_URL=/quiz/

# ============ 数据库 ============
DB_PATH=./data/app.db

# ============ GitHub OAuth（可选）============
# 在 https://github.com/settings/developers 创建 OAuth App
# Callback URL: https://你的域名.com/quiz/api/auth/callback/github  ← 子路径部署需带前缀
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
