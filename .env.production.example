# 生产环境 .env 示例
# 复制为 prod.env 后填入实际值(docker-compose 用 env_file 注入到容器进程环境)

# ============ 必须设置 ============
# better-auth 密钥：openssl rand -base64 32
BETTER_AUTH_SECRET=这里填入生成的密钥

# 应用对外可访问的根 URL（OAuth callback 用）
BETTER_AUTH_URL=https://你的域名.com

# ============ 数据库 ============
DB_PATH=./data/app.db

# ============ GitHub OAuth（可选）============
# 在 https://github.com/settings/developers 创建 OAuth App
# Callback URL: https://你的域名.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 是否在登录/注册页显示 GitHub 入口。
# 该开关由运行时 public runtimeConfig 控制(构建期默认 false),
# 配好上面的 GitHub 凭据后,这里必须设为 true 按钮才会出现。
NUXT_PUBLIC_HAS_GITHUB_LOGIN=true
